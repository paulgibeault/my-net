# /etc/litestream/litestream.yml
# Real-time SQLite replication to MinIO via S3-compatible API.
# Generated by Ansible.

dbs:
  - path: /pds/pds.sqlite
    replicas:
      - type: s3
        endpoint: {{ minio_endpoint }}
        bucket: {{ minio_bucket }}
        path: litestream/pds
        region: us-east-1
        force-path-style: true
        access-key-id: {{ minio_access_key }}
        secret-access-key: {{ minio_secret_key }}
        sync-interval: 1s        # stream WAL frames every second
        snapshot-interval: 24h   # full snapshot daily
