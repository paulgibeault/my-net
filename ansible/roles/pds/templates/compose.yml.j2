---
# /opt/pds/compose.yml — PDS stack
# Generated by Ansible — do not edit manually.

services:
  pds:
    image: {{ pds_image }}
    container_name: pds
    restart: unless-stopped
    env_file: pds.env
    volumes:
      - pds-data:/pds
    networks:
      - pds-net
    # No exposed ports — Cloudflare Tunnel connects directly via the tunnel container.
    labels:
      - "com.centurylinklabs.watchtower.enable=true"

  cloudflared:
    image: cloudflare/cloudflared:latest
    container_name: cloudflared
    restart: unless-stopped
    command: tunnel --no-autoupdate run
    environment:
      - TUNNEL_TOKEN={{ cloudflare_tunnel_token }}   # set in pds.env or vault
    networks:
      - pds-net
    depends_on:
      - pds

volumes:
  pds-data:

networks:
  pds-net:
    driver: bridge
