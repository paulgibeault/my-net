# /opt/pds/pds.env — PDS environment config
# Generated by Ansible — do not edit manually.
# SECRETS: chmod 600, never commit real values.

# ─── Core ──────────────────────────────────────────────────────────────────────
PDS_HOSTNAME={{ pds_domain }}
PDS_JWT_SECRET={{ pds_jwt_secret }}                     # generate: openssl rand -hex 32
PDS_ADMIN_PASSWORD={{ pds_admin_password }}             # strong random password
PDS_PLC_ROTATION_KEY_K256_PRIVATE_KEY_HEX={{ pds_plc_rotation_key }}  # from Ledger — KEEP OFFLINE

# ─── Handle domain ─────────────────────────────────────────────────────────────
PDS_SERVICE_HANDLE_DOMAINS=.{{ pds_handle_domain }}

# ─── Blob storage (MinIO via Tailscale) ────────────────────────────────────────
PDS_BLOBSTORE_S3_ENDPOINT={{ minio_endpoint }}
PDS_BLOBSTORE_S3_BUCKET={{ minio_bucket }}
PDS_BLOBSTORE_S3_REGION=us-east-1
PDS_BLOBSTORE_S3_ACCESS_KEY={{ minio_access_key }}
PDS_BLOBSTORE_S3_SECRET_KEY={{ minio_secret_key }}
PDS_BLOBSTORE_S3_FORCE_PATH_STYLE=true

# ─── SQLite + Litestream ───────────────────────────────────────────────────────
PDS_DB_SQLITE_LOCATION=/pds/pds.sqlite
PDS_SQLITE_DISABLE_WAL_AUTO_CHECKPOINT=true   # Litestream manages WAL

# ─── Email (invites + 2FA) ─────────────────────────────────────────────────────
PDS_EMAIL_SMTP_URL=smtps://{{ smtp_user }}:{{ smtp_password }}@{{ smtp_host }}:465
PDS_EMAIL_FROM_ADDRESS=noreply@{{ pds_domain }}

# ─── Invite-only mode ──────────────────────────────────────────────────────────
PDS_INVITE_REQUIRED=true
