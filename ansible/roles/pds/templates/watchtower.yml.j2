---
# /opt/pds/watchtower.yml — Watchtower Docker Compose override
# Merged with compose.yml at deploy time by Ansible.
# Generated by Ansible — do not edit manually.

services:
  watchtower:
    image: containrrr/watchtower:latest
    container_name: watchtower
    restart: unless-stopped
    volumes:
      - /var/run/docker.sock:/var/run/docker.sock
    environment:
      # Only watch containers that opt in via label
      - WATCHTOWER_LABEL_ENABLE=true
      # Check interval in seconds (300 = every 5 minutes)
      - WATCHTOWER_POLL_INTERVAL=300
      # Remove old images after update
      - WATCHTOWER_CLEANUP={{ watchtower_cleanup | default(true) | lower }}
      # Log level
      - WATCHTOWER_LOG_LEVEL=info
    networks:
      - pds-net
